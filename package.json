{
  "name": "figma-mcp-helper",
  "displayName": "Figma MCP Helper",
  "description": "Figma MCP + AI Agent code generation for VSCode",
  "version": "0.1.2",
  "publisher": "bd-creative",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/birdea/vscode-figmalab.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:figma-mcp-helper.figma"
  ],
  "icon": "resources/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "figma-mcp-helper",
          "title": "Figma MCP Helper",
          "icon": "resources/icon-activity.png"
        }
      ]
    },
    "views": {
      "figma-mcp-helper": [
        {
          "type": "webview",
          "id": "figma-mcp-helper.figma",
          "name": "Figma"
        },
        {
          "type": "webview",
          "id": "figma-mcp-helper.agent",
          "name": "Agent"
        },
        {
          "type": "webview",
          "id": "figma-mcp-helper.prompt",
          "name": "Prompt"
        },
        {
          "type": "webview",
          "id": "figma-mcp-helper.log",
          "name": "Log"
        }
      ]
    },
    "commands": [
      {
        "command": "figma-mcp-helper.connect",
        "title": "MCP 연결",
        "icon": "$(plug)"
      },
      {
        "command": "figma-mcp-helper.generate",
        "title": "Figma MCP Helper: Generate Code"
      },
      {
        "command": "figma-mcp-helper.agent.save",
        "title": "Agent 설정 저장",
        "icon": "$(save)"
      },
      {
        "command": "figma-mcp-helper.agent.clear",
        "title": "Agent 설정 초기화",
        "icon": "$(trash)"
      },
      {
        "command": "figma-mcp-helper.prompt.generate",
        "title": "코드 생성",
        "icon": "$(play)"
      },
      {
        "command": "figma-mcp-helper.log.clear",
        "title": "Clear Logs",
        "icon": "$(clear-all)"
      },
      {
        "command": "figma-mcp-helper.log.copy",
        "title": "Copy Logs",
        "icon": "$(copy)"
      },
      {
        "command": "figma-mcp-helper.log.save",
        "title": "Save Logs",
        "icon": "$(save)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "figma-mcp-helper.connect",
          "when": "view == figma-mcp-helper.figma",
          "group": "navigation@1"
        },
        {
          "command": "figma-mcp-helper.agent.save",
          "when": "view == figma-mcp-helper.agent",
          "group": "navigation@1"
        },
        {
          "command": "figma-mcp-helper.agent.clear",
          "when": "view == figma-mcp-helper.agent",
          "group": "navigation@2"
        },
        {
          "command": "figma-mcp-helper.prompt.generate",
          "when": "view == figma-mcp-helper.prompt",
          "group": "navigation@1"
        },
        {
          "command": "figma-mcp-helper.log.clear",
          "when": "view == figma-mcp-helper.log",
          "group": "navigation@1"
        },
        {
          "command": "figma-mcp-helper.log.copy",
          "when": "view == figma-mcp-helper.log",
          "group": "navigation@2"
        },
        {
          "command": "figma-mcp-helper.log.save",
          "when": "view == figma-mcp-helper.log",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Figma MCP Helper",
      "properties": {
        "figma-mcp-helper.defaultAgent": {
          "type": "string",
          "enum": [
            "gemini",
            "claude"
          ],
          "default": "gemini",
          "description": "Default AI agent to use"
        },
        "figma-mcp-helper.mcpEndpoint": {
          "type": "string",
          "default": "http://localhost:3845",
          "description": "Figma MCP server endpoint"
        },
        "figma-mcp-helper.openFetchedDataInEditor": {
          "type": "boolean",
          "default": false,
          "description": "Open fetched MCP JSON in a VS Code editor automatically after a successful fetch"
        },
        "figma-mcp-helper.claudeModels": {
          "type": "array",
          "default": [
            {
              "id": "claude-opus-4-6",
              "name": "Claude Opus 4.6",
              "description": "Most capable Claude",
              "inputTokenLimit": 200000,
              "outputTokenLimit": 8192
            },
            {
              "id": "claude-sonnet-4-6",
              "name": "Claude Sonnet 4.6",
              "description": "Latest Claude Sonnet",
              "inputTokenLimit": 200000,
              "outputTokenLimit": 8192
            },
            {
              "id": "claude-haiku-4-5-20251001",
              "name": "Claude Haiku 4.5",
              "description": "Fast and efficient",
              "inputTokenLimit": 200000,
              "outputTokenLimit": 8192
            }
          ],
          "description": "Claude model catalog used in the Agent panel",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "inputTokenLimit": { "type": "number" },
              "outputTokenLimit": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.js --production",
    "watch": "node esbuild.config.js --watch",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "node ./out/test/runTest.js",
    "test:unit": "mocha --ui tdd --require tsx --require test/unit/globalSetup.ts \"test/unit/**/*.test.ts\"",
    "test:coverage": "c8 --all --src \"src\" --exclude \"src/types.ts\" --reporter text --reporter html npm run test:unit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20.0.0",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.22.0",
    "c8": "^11.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "mocha": "^11.7.5",
    "module-alias": "^2.3.4",
    "nock": "^14.0.11",
    "prettier": "^3.8.1",
    "sinon": "^21.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.3.0",
    "@vscode/codicons": "^0.0.44"
  }
}
